# DeepAssist Environment Configuration
# 이 파일을 .env로 복사하여 사용하세요: cp .env.example .env

# ── LLM 프로바이더 기본값 ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
VLLM_BASE_URL=http://localhost:8000
VLLM_DEFAULT_MODEL=Qwen/Qwen3-8B
GEMINI_DEFAULT_MODEL=gemini-2.5-flash-lite

# ── 임베딩 설정 ──
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=bge-m3:latest
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_API_KEY=
CODE_EMBEDDING_MODEL=

# ── OpenAI 호환 직접 연결 설정 (프록시 미기동) ──
# Provider에서 "OpenAI" 선택 시 아래 환경변수로 외부 프록시/API에 직접 연결
ANTHROPIC_BASE_URL=http://localhost:8082
ANTHROPIC_API_KEY=sk-xxx
ANTHROPIC_DEFAULT_SONNET_MODEL=openai/GLM-4.7
ANTHROPIC_DEFAULT_OPUS_MODEL=openai/GLM-4.7
ANTHROPIC_DEFAULT_HAIKU_MODEL=openai/GLM-4.7

# ── claude-code-proxy 설정 ──
PROXY_PORT=8082
PROXY_MAX_WAIT=15

# ── 파일 서버 설정 ──
FILE_SERVER_URL=http://localhost:8000
FILE_SERVER_PORT=8000

# ── 워크스페이스 설정 ──
WORKSPACES_ROOT=./workspaces
MAX_FILE_SIZE_MB=100
MAX_WORKSPACE_SIZE_MB=100
WORKSPACE_EXPIRE_HOURS=24
CLEANUP_INTERVAL_MINUTES=30

# ── CORS 설정 ──
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── 에이전트 설정 ──
AGENT_MAX_TURNS=150
DEEPASSIST_MD_MAX_SIZE=50000

# ── Knowledge DB 설정 ──
KNOWLEDGE_BASE_DIR=~/.deepassist/knowledge

# ── OpenRouter 설정 (선택) ──
OPENROUTER_API_KEY=
